# =========================================
# App Environment
# =========================================
NEXT_PUBLIC_CONTEXT=development

# Optional base path.
# Leave empty for Vercel root deployment.
NEXT_PUBLIC_BASE_PATH=

# Static asset path
NEXT_PUBLIC_ASSET_LOGO=/images/logo_light.png

# =========================================
# Auth - NextAuth
# =========================================
# Local:
# NEXTAUTH_URL=http://localhost:3000
#
# Production:
# In Vercel, this may be omitted if Vercel system env is enabled,
# but setting it explicitly is also fine.
NEXTAUTH_URL=http://localhost:3000

# Required in production.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# =========================================
# API Endpoints
# =========================================
# For local demo, this can point to the same Next.js app.
NEXT_PUBLIC_DB_API_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_API_URL=http://localhost:3000

# Optional external Node/API server.
# Used only if the app calls a separate backend.
NEXT_PUBLIC_NODE_API_URL=http://localhost:4000